# Runtime
BUILI_ENVIRONMENT=development
BUILI_LOG_LEVEL=INFO
BUILI_DATABASE_URL=sqlite+aiosqlite:///./.data/buili.db
# Worker-only URL in deployed worker tasks; never inject this into the API task.
BUILI_WORKER_DATABASE_URL=
BUILI_PUBLIC_API_URL=http://localhost:8000
BUILI_CORS_ORIGINS=http://localhost:3000

# Internal access tokens. Generate a long random value before production.
BUILI_JWT_SECRET=replace-with-at-least-32-random-characters
BUILI_JWT_ISSUER=https://api.builiconstruction.com
BUILI_JWT_AUDIENCE=buili-web
# Leave unset in production so cookies remain host-only to api.builiconstruction.com.
BUILI_COOKIE_DOMAIN=
BUILI_COOKIE_SECURE=false
BUILI_COOKIE_SAMESITE=lax
# Production only: injected by a Cloudflare Transform Rule and never exposed to browsers.
BUILI_ORIGIN_VERIFY_SECRET=
BUILI_FRONTEND_URL=http://localhost:3000
BUILI_EMAIL_BACKEND=disabled
BUILI_REQUIRE_EMAIL_VERIFICATION=false

# Google / OIDC. The frontend sends a provider ID token to /v1/auth/oidc/exchange.
BUILI_OIDC_ISSUER=https://accounts.google.com
BUILI_OIDC_CLIENT_ID=

# Object storage: local or s3
BUILI_STORAGE_BACKEND=local
BUILI_STORAGE_ROOT=.data/storage
BUILI_MAX_UPLOAD_BYTES=99614720
BUILI_MALWARE_SCANNER_BACKEND=disabled
BUILI_CLAMAV_HOST=127.0.0.1
BUILI_CLAMAV_PORT=3310
BUILI_MAX_ARCHIVE_ENTRIES=10000
BUILI_MAX_ARCHIVE_UNCOMPRESSED_BYTES=536870912
BUILI_MAX_ARCHIVE_COMPRESSION_RATIO=100
BUILI_MAX_PDF_PAGES=500
BUILI_MAX_EXTRACTED_TEXT_CHARS=5000000
BUILI_MAX_IMAGE_PIXELS=100000000
BUILI_S3_BUCKET=
BUILI_S3_REGION=us-west-1
BUILI_S3_ENDPOINT_URL=

# Background processing: local or sqs
BUILI_JOB_BACKEND=local
BUILI_SQS_QUEUE_URL=
BUILI_SQS_ENDPOINT_URL=
BUILI_JOB_VISIBILITY_TIMEOUT_SECONDS=900
BUILI_JOB_HEARTBEAT_SECONDS=300

# OpenAI is optional; never commit a key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
BUILI_EXTERNAL_AI_ENABLED=false
BUILI_OPENAI_TIMEOUT_SECONDS=30

# Optional 2D -> 3D service adapter (can point to a future GPU worker).
BUILI_SPATIAL_PROCESSOR_URL=

# Demo persona. Disabled by default and forbidden in production.
BUILI_DEMO_MODE=false
BUILI_DEMO_EMAIL=jordan@demo.builiconstruction.com
BUILI_DEMO_PASSWORD=ChangeMe-Demo-2026!
BUILI_DEMO_EVIDENCE_PATH=../../buili_demo_evidence
